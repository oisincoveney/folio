{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pipeline-gateway": {
      "enabled": true,
      "headers": {
        "Authorization": "{env:PIPELINE_MCP_GATEWAY_AUTHORIZATION}"
      },
      "type": "remote",
      "url": "https://pipeline-mcp.momokaya.ee/mcp/"
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:./prompts/codex-default.md}"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "skills": {
    "paths": [
      "../.agents/skills"
    ]
  },
  "plugin": [
    "oc-codex-multi-auth",
    "@devtheops/opencode-plugin-otel@1.1.0",
    "@prevalentware/opencode-goal-plugin"
  ],
  "lsp": true
}
