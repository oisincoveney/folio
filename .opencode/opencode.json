{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pipeline-gateway": {
      "enabled": true,
      "headers": {
        "Authorization": "{env:PIPELINE_MCP_GATEWAY_AUTHORIZATION}"
      },
      "type": "remote",
      "url": "https://pipeline-mcp.momokaya.ee/mcp/"
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "prompt": "{file:./prompts/codex-default.md}"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "skills": {
    "paths": [
      "../.agents/skills"
    ]
  }
}
